# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
*.pyc

# Backup files
*.backup
*.bak
*~

# Temporary files
*.tmp
*.temp
*.log

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# SQLReaper - Generated files
results/
profiles/*.json
uploads/*
!uploads/.gitkeep

# Database files
*.db
*.sqlite
*.sqlite3

# Weird pip artifacts (from bad installs)
=*.*.*
[0-9]

# Secrets
*.key
*.pem
*.secret
*.env

# Keep important empty directories
!results/.gitkeep
!profiles/.gitkeep
!uploads/.gitkeep

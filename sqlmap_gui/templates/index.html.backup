                                <div class="dork-item" data-dork="inurl:.php?id= site:.nz"><code>inurl:.php?id= site:.nz</code><span>New Zealand sites</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id= site:.sg"><code>inurl:.php?id= site:.sg</code><span>Singapore sites</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id= site:.my"><code>inurl:.php?id= site:.my</code><span>Malaysian sites</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id= site:.th"><code>inurl:.php?id= site:.th</code><span>Thai sites</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id= site:.vn"><code>inurl:.php?id= site:.vn</code><span>Vietnamese sites</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id= site:.ph"><code>inurl:.php?id= site:.ph</code><span>Philippine sites</span></div>
                            </div></div>
                            <div class="dork-category"><h3>&#128194; CMS & WordPress Dorks</h3><span class="dork-diff medium">Medium</span><div class="dork-list">
                                <div class="dork-item" data-dork="inurl:/wp-content/plugins/"><code>inurl:/wp-content/plugins/</code><span>WordPress plugins</span></div>
                                <div class="dork-item" data-dork="inurl:/wp-content/themes/"><code>inurl:/wp-content/themes/</code><span>WordPress themes</span></div>
                                <div class="dork-item" data-dork="inurl:/wp-includes/"><code>inurl:/wp-includes/</code><span>WordPress includes</span></div>
                                <div class="dork-item" data-dork="inurl:index.php?option=com_"><code>inurl:option=com_</code><span>Joomla components</span></div>
                                <div class="dork-item" data-dork="inurl:index.php?option=com_content&view=article&id="><code>Joomla article ID</code><span>Joomla article view</span></div>
                                <div class="dork-item" data-dork="inurl:index.php?route=product/"><code>inurl:route=product/</code><span>OpenCart products</span></div>
                                <div class="dork-item" data-dork="inurl:node/"><code>inurl:node/</code><span>Drupal nodes</span></div>
                                <div class="dork-item" data-dork="inurl:/drupal/node/"><code>inurl:/drupal/node/</code><span>Drupal node URLs</span></div>
                                <div class="dork-item" data-dork="inurl:/magento/"><code>inurl:/magento/</code><span>Magento installs</span></div>
                                <div class="dork-item" data-dork="inurl:/prestashop/"><code>inurl:/prestashop/</code><span>PrestaShop installs</span></div>
                                <div class="dork-item" data-dork="inurl:/shopify/"><code>inurl:/shopify/</code><span>Shopify stores</span></div>
                                <div class="dork-item" data-dork="inurl:/joomla/administrator/"><code>inurl:joomla/admin</code><span>Joomla admin paths</span></div>
                                <div class="dork-item" data-dork="inurl:/wordpress/wp-admin/"><code>inurl:wp-admin</code><span>WordPress admin</span></div>
                            </div></div>
                            <div class="dork-category"><h3>&#128218; Directory Listing & Index Dorks</h3><span class="dork-diff medium">Medium</span><div class="dork-list">
                                <div class="dork-item" data-dork="intitle:\"index of\" intext:\"parent directory\""><code>"index of" parent dir</code><span>Open directories</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" \"backup\""><code>"index of" backup</code><span>Backup directories</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" \"database\""><code>"index of" database</code><span>Database directories</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" \"wp-content\""><code>"index of" wp-content</code><span>WordPress file lists</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" /etc/passwd"><code>"index of" passwd</code><span>Exposed passwd files</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" shadow"><code>"index of" shadow</code><span>Exposed shadow files</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" phpmyadmin"><code>"index of" phpmyadmin</code><span>Exposed phpMyAdmin</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" admin"><code>"index of" admin</code><span>Admin directories</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" config"><code>"index of" config</code><span>Config directories</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" secret"><code>"index of" secret</code><span>Secret directories</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" .git"><code>"index of" .git</code><span>Exposed .git dirs</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" .env"><code>"index of" .env</code><span>Exposed .env files</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" web.config"><code>"index of" web.config</code><span>Exposed web.config</span></div>
                                <div class="dork-item" data-dork="intitle:\"index of\" dump.sql"><code>"index of" dump.sql</code><span>SQL dump files</span></div>
                            </div></div>
                            <div class="dork-category"><h3>&#128272; Authentication & Session Dorks</h3><span class="dork-diff hard">Hard</span><div class="dork-list">
                                <div class="dork-item" data-dork="inurl:token= intext:access"><code>inurl:token= access</code><span>Access token URLs</span></div>
                                <div class="dork-item" data-dork="inurl:session.php?sessid="><code>inurl:session.php?sessid=</code><span>Session ID params</span></div>
                                <div class="dork-item" data-dork="inurl:auth.php?token="><code>inurl:auth.php?token=</code><span>Auth token params</span></div>
                                <div class="dork-item" data-dork="inurl:api_key="><code>inurl:api_key=</code><span>API key in URLs</span></div>
                                <div class="dork-item" data-dork="inurl:apikey="><code>inurl:apikey=</code><span>API key alternate</span></div>
                                <div class="dork-item" data-dork="inurl:secret_key="><code>inurl:secret_key=</code><span>Secret key params</span></div>
                                <div class="dork-item" data-dork="inurl:auth_token="><code>inurl:auth_token=</code><span>Auth token params</span></div>
                                <div class="dork-item" data-dork="inurl:access_token="><code>inurl:access_token=</code><span>Access token params</span></div>
                                <div class="dork-item" data-dork="inurl:refresh_token="><code>inurl:refresh_token=</code><span>Refresh token params</span></div>
                                <div class="dork-item" data-dork="inurl:client_id="><code>inurl:client_id=</code><span>OAuth client ID</span></div>
                                <div class="dork-item" data-dork="inurl:client_secret="><code>inurl:client_secret=</code><span>OAuth client secret</span></div>
                                <div class="dork-item" data-dork="inurl:oauth/token"><code>inurl:oauth/token</code><span>OAuth token endpoints</span></div>
                            </div></div>
                            <div class="dork-category"><h3>&#127912; Error-Based SQLi Dorks</h3><span class="dork-diff hard">Hard</span><div class="dork-list">
                                <div class="dork-item" data-dork="intext:'You have an error in your SQL syntax'"><code>"SQL syntax error"</code><span>MySQL syntax error</span></div>
                                <div class="dork-item" data-dork="intext:'Warning: mysql_query()'"><code>"mysql_query() warn"</code><span>MySQL query warning</span></div>
                                <div class="dork-item" data-dork="intext:'Warning: mysql_fetch_assoc()'"><code>"mysql_fetch_assoc"</code><span>MySQL fetch warning</span></div>
                                <div class="dork-item" data-dork="intext:'Warning: mysql_num_rows'"><code>"mysql_num_rows"</code><span>MySQL num rows warn</span></div>
                                <div class="dork-item" data-dork="intext:'MySQL Error:'"><code>"MySQL Error:"</code><span>MySQL error messages</span></div>
                                <div class="dork-item" data-dork="intext:'ODBC Microsoft Access Driver'"><code>"ODBC Access"</code><span>Access DB errors</span></div>
                                <div class="dork-item" data-dork="intext:'Microsoft JET Database Engine'"><code>"JET Database"</code><span>JET DB engine error</span></div>
                                <div class="dork-item" data-dork="intext:'Unclosed quotation mark'"><code>"Unclosed quote"</code><span>SQL quote errors</span></div>
                                <div class="dork-item" data-dork="intext:'Incorrect syntax near'"><code>"Incorrect syntax"</code><span>MSSQL syntax error</span></div>
                                <div class="dork-item" data-dork="intext:'Fatal error: Uncaught'"><code>"Fatal error Uncaught"</code><span>PHP fatal errors</span></div>
                                <div class="dork-item" data-dork="intext:'Stack trace:'"><code>"Stack trace:"</code><span>PHP stack traces</span></div>
                                <div class="dork-item" data-dork="intext:'PDOException'"><code>"PDOException"</code><span>PDO exceptions</span></div>
                                <div class="dork-item" data-dork="intext:'ActiveRecord::StatementInvalid'"><code>"ActiveRecord"</code><span>Rails SQL errors</span></div>
                                <div class="dork-item" data-dork="intext:'java.sql.SQLException'"><code>"java.sql.SQLException"</code><span>Java SQL exceptions</span></div>
                                <div class="dork-item" data-dork="intext:'org.postgresql.util.PSQLException'"><code>"PSQLException"</code><span>PostgreSQL errors</span></div>
                                <div class="dork-item" data-dork="intext:'ORA-00933'"><code>"ORA-00933"</code><span>Oracle SQL error</span></div>
                                <div class="dork-item" data-dork="intext:'ORA-01756'"><code>"ORA-01756"</code><span>Oracle quote error</span></div>
                                <div class="dork-item" data-dork="intext:'ORA-00921'"><code>"ORA-00921"</code><span>Oracle unexpected</span></div>
                                <div class="dork-item" data-dork="intext:'sqlite3.OperationalError'"><code>"sqlite3 error"</code><span>SQLite errors</span></div>
                            </div></div>
                            <div class="dork-category"><h3>&#128273; Sensitive Data Exposure Dorks</h3><span class="dork-diff advanced">Advanced</span><div class="dork-list">
                                <div class="dork-item" data-dork="intext:\"INSERT INTO\" ext:sql OR ext:txt OR ext:log"><code>SQL INSERT statements</code><span>Database inserts</span></div>
                                <div class="dork-item" data-dork="intext:\"CREATE TABLE\" ext:sql OR ext:txt"><code>CREATE TABLE statements</code><span>Table definitions</span></div>
                                <div class="dork-item" data-dork="intext:\"password values\" ext:sql"><code>password values SQL</code><span>Password INSERTs</span></div>
                                <div class="dork-item" data-dork="intext:\"username\" AND \"password\" AND intext:\"login\" ext:sql OR ext:txt"><code>username password login</code><span>Credential files</span></div>
                                <div class="dork-item" data-dork="ext:php intext:password intext:mysql_connect"><code>PHP mysql connect</code><span>DB connection files</span></div>
                                <div class="dork-item" data-dork="ext:php intext:password intext:mysql_select_db"><code>PHP mysql select db</code><span>DB selection files</span></div>
                                <div class="dork-item" data-dork="ext:php intext:password intext:PDO"><code>PHP PDO credentials</code><span>PDO connection files</span></div>
                                <div class="dork-item" data-dork="ext:php intext:password intext:mysqli"><code>PHP mysqli credentials</code><span>MySQLi connection</span></div>
                                <div class="dork-item" data-dork="intext:\"connection string\" ext:txt OR ext:log"><code>"connection string"</code><span>Connection strings</span></div>
                                <div class="dork-item" data-dork="intext:\"jdbc:\" ext:properties OR ext:xml"><code>"jdbc:" connection</code><span>JDBC connections</span></div>
                                <div class="dork-item" data-dork="ext:pem OR ext:key OR ext:crt intext:\"-----BEGIN\""><code>ext:pem key crt</code><span>Certificate/key files</span></div>
                                <div class="dork-item" data-dork="intext:\"private key\" ext:pem OR ext:key OR ext:txt"><code>"private key"</code><span>Private key files</span></div>
                                <div class="dork-item" data-dork="ext:ppk OR ext:ppks intext:\"PuTTY\""><code>ext:ppk PuTTY</code><span>PuTTY private keys</span></div>
                                <div class="dork-item" data-dork="intext:\"ssh-rsa\" ext:txt OR ext:pem"><code>"ssh-rsa" key</code><span>SSH RSA keys</span></div>
                            </div></div>
                            <div class="dork-category"><h3>&#128640; Injection-Ready Complex Dorks</h3><span class="dork-diff advanced">Advanced</span><div class="dork-list">
                                <div class="dork-item" data-dork="inurl:index.php?id= inurl:page= inurl:lang="><code>id+page+lang combo</code><span>Triple param injection</span></div>
                                <div class="dork-item" data-dork="inurl:products.php?cat= inurl:index.php?id="><code>cat+id combo</code><span>Category+ID injection</span></div>
                                <div class="dork-item" data-dork="inurl:news.php?id= AND intext:warning"><code>news+warning</code><span>News with warnings</span></div>
                                <div class="dork-item" data-dork="inurl:article.php?id= AND inurl:view.php?id="><code>article+view combo</code><span>Article view injection</span></div>
                                <div class="dork-item" data-dork="inurl:product.php?id= AND inurl:category="><code>product+category</code><span>Product category injection</span></div>
                                <div class="dork-item" data-dork="inurl:gallery.php?id= AND intext:photo"><code>gallery+photo</code><span>Gallery photo injection</span></div>
                                <div class="dork-item" data-dork="inurl:download.php?id= AND inurl:file="><code>download+file combo</code><span>File download injection</span></div>
                                <div class="dork-item" data-dork="inurl:search.php?search= AND inurl:results="><code>search+results</code><span>Search results injection</span></div>
                                <div class="dork-item" data-dork="inurl:order.php?id= inurl:checkout.php?id="><code>order+checkout</code><span>Order flow injection</span></div>
                                <div class="dork-item" data-dork="inurl:profile.php?id= AND intext:username"><code>profile+username</code><span>Profile injection</span></div>
                                <div class="dork-item" data-dork="inurl:member.php?id= inurl:profile_view.php?id="><code>member+profile view</code><span>Member profile injection</span></div>
                                <div class="dork-item" data-dork="inurl:calendar.php?event="><code>calendar event param</code><span>Calendar injection</span></div>
                                <div class="dork-item" data-dork="inurl:forum.php?topic="><code>forum topic param</code><span>Forum topic injection</span></div>
                                <div class="dork-item" data-dork="inurl:thread.php?id="><code>thread ID param</code><span>Thread injection</span></div>
                                <div class="dork-item" data-dork="inurl:comment.php?id="><code>comment ID param</code><span>Comment injection</span></div>
                                <div class="dork-item" data-dork="inurl:feedback.php?id="><code>feedback ID param</code><span>Feedback injection</span></div>
                            </div></div>
                        </div>
                    </div></div>
                </div>
                <!-- Profiles -->
                <div class="tab-content" id="profiles">
                    <div class="panel"><div class="panel-header"><span>&#128190; Scan Profiles</span></div><div class="panel-content">
                        <form id="profile-form"><div class="form-group"><label for="profile-name">Profile Name</label><input type="text" id="profile-name" placeholder="My Custom Profile" required></div><div class="form-group"><label for="profile-options">Custom Options</label><textarea id="profile-options" rows="5" placeholder="--batch --random-agent --level=3"></textarea></div><div class="button-group"><button type="submit" class="btn-primary">&#128190; Save</button></div></form>
                        <div id="profiles-list" style="margin-top:16px;"><h4>Saved Profiles</h4><div id="profiles-container"></div></div>
                    </div></div>
                </div>
            </div>
            <!-- Right Panel -->
            <div class="right-panel">
                <div class="panel">
                    <div class="panel-header"><span>&#128250; Scan Results</span>
                        <div class="panel-actions"><button class="btn-icon" id="copy-output-btn" title="Copy">&#128203;</button><button class="btn-icon" id="export-pdf-btn" title="Export">&#128196;</button><span class="scan-meta" id="scan-meta"></span></div>
                    </div>
                    <div class="panel-content">
                        <div class="scan-progress" id="scan-progress"><div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div><div class="progress-text" id="progress-text">Ready</div></div>
                        <div class="scan-results" id="scan-results">
                            <div class="terminal-window"><div class="terminal-header"><span class="terminal-dots"><span class="dot dot-red"></span><span class="dot dot-yellow"></span><span class="dot dot-green"></span></span><span class="terminal-title">Terminal</span></div>
                            <pre id="output">[+] SQLMap GUI v2.1 - Advanced Penetration Testing Framework&#10;[+] Ready to scan. Configure target and click "Start Scan".&#10;[+] Ctrl+Enter to start | Escape to stop</pre>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="panel"><div class="panel-header"><span>&#128193; File Upload</span></div><div class="panel-content">
                    <div class="upload-area" id="upload-area"><div class="upload-icon">&#128193;</div><p>Drag & drop or click to browse</p><small>.txt .sql .req .http .log .json .xml</small><input type="file" id="file-input" style="display:none" accept=".txt,.sql,.req,.http,.log,.json,.xml"></div>
                    <div id="upload-result"></div>
                </div></div>
                <div class="panel"><div class="panel-header"><span>&#128338; Scan History</span><button class="btn-small" id="clear-history-btn">&#128465; Clear</button></div><div class="panel-content"><div id="scan-history" class="history-list"><div class="history-empty">Loading...</div></div></div></div>
            </div>
        </div>
        <div class="footer"><div class="footer-stats"><span id="total-scans">Total: --</span><span id="successful-scans">OK: --</span><span id="failed-scans">Err: --</span></div><div class="footer-info">SQLMap GUI v2.1 | SQL Injection Testing Tool</div></div>
    </div>
    <!-- Modals -->
    <div class="modal" id="shortcuts-modal"><div class="modal-content"><div class="modal-header"><h3>&#9000; Keyboard Shortcuts</h3><button class="modal-close" id="shortcuts-close">&times;</button></div><div class="modal-body"><div class="shortcut-table"><div class="shortcut-row"><kbd>Ctrl</kbd>+<kbd>Enter</kbd><span>Start Scan</span></div><div class="shortcut-row"><kbd>Escape</kbd><span>Stop Scan</span></div><div class="shortcut-row"><kbd>Ctrl</kbd>+<kbd>S</kbd><span>Save Profile</span></div><div class="shortcut-row"><kbd>Ctrl</kbd>+<kbd>L</kbd><span>Clear Output</span></div><div class="shortcut-row"><kbd>Ctrl</kbd>+<kbd>K</kbd><span>Focus URL</span></div><div class="shortcut-row"><kbd>Tab</kbd><span>Next Tab</span></div><div class="shortcut-row"><kbd>Shift</kbd>+<kbd>Tab</kbd><span>Prev Tab</span></div></div></div></div></div>
    <div class="modal" id="settings-modal"><div class="modal-content"><div class="modal-header"><h3>&#9881; Settings</h3><button class="modal-close" id="settings-close">&times;</button></div><div class="modal-body"><div id="settings-content">Loading...</div></div></div></div>
    <div class="modal" id="export-modal"><div class="modal-content"><div class="modal-header"><h3>&#128196; Export Results</h3><button class="modal-close" id="export-close">&times;</button></div><div class="modal-body"><div class="export-options"><button class="export-btn" data-format="txt">&#128196; Text (.txt)</button><button class="export-btn" data-format="md">&#128220; Markdown (.md)</button><button class="export-btn" data-format="html">&#127760; HTML (.html)</button><button class="export-btn" data-format="json">&#128202; JSON (.json)</button></div></div></div></div>
    <div class="modal" id="save-profile-modal"><div class="modal-content"><div class="modal-header"><h3>&#128190; Save Profile</h3><button class="modal-close" id="save-profile-close">&times;</button></div><div class="modal-body"><div class="form-group"><label>Name</label><input type="text" id="modal-profile-name" placeholder="Profile name"></div><div class="button-group"><button class="btn-primary" id="modal-save-profile">Save</button></div></div></div></div>
    <script src="/static/js/main.js"></script>
</body>
</html>
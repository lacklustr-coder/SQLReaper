<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SQLReaper v2.1</title>
    <link rel="stylesheet" href="/static/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <div id="toast-container"></div>
    <div class="container">
        <div class="header">
            <div class="header-top">
                <div>
                    <h1 class="glitch" data-text="SQLReaper">SQLReaper</h1>
                    <div class="subtitle">Advanced SQL Injection Penetration Testing Framework v2.1</div>
                </div>
                <div class="header-actions">
                    <button id="theme-toggle" class="icon-btn" title="Toggle Theme">&#127769;</button>
                    <button id="shortcuts-btn" class="icon-btn" title="Keyboard Shortcuts">&#9000;</button>
                    <button id="settings-btn" class="icon-btn" title="Settings">&#9881;</button>
                </div>
            </div>
            <div class="health-status" id="health-status">
                <span class="status-dot" id="health-dot"></span>
                <span id="health-text">Checking...</span>
            </div>
        </div>
        <div class="tab-navigation">
            <button class="tab-btn active" data-tab="direct-scan">&#127919; Direct Scan</button>
            <button class="tab-btn" data-tab="batch-scan">&#128202; Batch Scan</button>
            <button class="tab-btn" data-tab="google-dork">&#128269; Google Dorking</button>
            <button class="tab-btn" data-tab="multi-dork">&#128203; Multi-Dork</button>
            <button class="tab-btn" data-tab="dork-library">&#128218; Dork Library</button>
            <button class="tab-btn" data-tab="profiles">&#128190; Profiles</button>
        </div>
        <div class="main-content">
            <div class="left-panel">
                <!-- Direct Scan -->
                <div class="tab-content active" id="direct-scan">
                    <div class="panel">
                        <div class="panel-header">
                            <span class="status-indicator" id="status-indicator"></span>
                            <span>Direct Scan Configuration</span>
                            <div class="panel-actions">
                                <button class="btn-icon" id="save-profile-btn" title="Save Profile">&#128190;</button>
                                <button class="btn-icon" id="load-profile-btn" title="Load Profile">&#128194;</button>
                            </div>
                        </div>
                        <div class="panel-content">
                            <form id="scan-form">
                                <div class="form-group">
                                    <label for="target">Target URL *</label>
                                    <input type="url" id="target" placeholder="http://example.com/page.php?id=1" required>
                                </div>
                                <div class="form-row">
                                    <div class="form-group"><label for="method">HTTP Method</label>
                                        <select id="method"><option value="GET">GET</option><option value="POST">POST</option><option value="PUT">PUT</option><option value="DELETE">DELETE</option><option value="PATCH">PATCH</option><option value="OPTIONS">OPTIONS</option></select>
                                    </div>
                                    <div class="form-group"><label for="timeout">Timeout (sec)</label><input type="number" id="timeout" value="300" min="30" max="3600"></div>
                                </div>
                                <div class="form-group"><label for="data">POST Data</label><textarea id="data" rows="2" placeholder="username=admin&password=test"></textarea></div>
                                <div class="form-group"><label for="cookie">Cookie</label><input type="text" id="cookie" placeholder="PHPSESSID=123456; user=admin"></div>
                                <div class="form-group"><label for="user-agent">User-Agent</label><input type="text" id="user-agent" placeholder="Custom User-Agent"></div>
                                <div class="form-group"><label for="headers">Headers (one per line)</label><textarea id="headers" rows="2" placeholder="Authorization: Bearer token"></textarea></div>
                                <div class="form-group"><label for="proxy-url">Proxy URL</label><input type="text" id="proxy-url" placeholder="http://127.0.0.1:8080"></div>
                                <div class="scan-options">
                                    <h4>Quick Options:</h4>
                                    <div class="option-checkbox"><input type="checkbox" id="batch" checked><label for="batch">Batch Mode</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="random-agent"><label for="random-agent">Random User-Agent</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="tor"><label for="tor">Use Tor</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="flush-session" checked><label for="flush-session">Flush Session</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="smart-check"><label for="smart-check">Smart Check</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="force-ssl"><label for="force-ssl">Force SSL</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="skip-waf"><label for="skip-waf">Skip WAF</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="no-cast"><label for="no-cast">No Cast</label></div>
                                </div>
                                <div class="scan-options">
                                    <h4>Enumeration:</h4>
                                    <div class="option-checkbox"><input type="checkbox" id="dbs"><label for="dbs">All Databases</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="tables"><label for="tables">Tables</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="columns"><label for="columns">Columns</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="dump"><label for="dump">Dump Data</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="users"><label for="users">DB Users</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="passwords"><label for="passwords">Password Hashes</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="roles"><label for="roles">DB Roles</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="privileges"><label for="privileges">DB Privileges</label></div>
                                </div>
                                <div class="scan-options">
                                    <h4>Advanced:</h4>
                                    <div class="option-checkbox"><input type="checkbox" id="risk"><label for="risk">High Risk (3)</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="level"><label for="level">High Level (5)</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="tamper"><label for="tamper">Tamper Scripts</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="os-shell"><label for="os-shell">OS Shell</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="sql-shell"><label for="sql-shell">SQL Shell</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="file-read"><label for="file-read">File Read</label></div>
                                </div>
                                <div class="form-group"><label for="custom-options">Custom Options</label><textarea id="custom-options" rows="2" placeholder="--delay=1 --retries=3"></textarea></div>
                                <div class="button-group">
                                    <button type="submit" class="btn-primary" id="scan-btn"><span class="btn-text">&#128640; Start Scan</span><span class="btn-loading" style="display:none;">&#9203; Scanning...</span></button>
                                    <button type="button" class="btn-secondary" id="stop-btn" disabled>&#9209; Stop</button>
                                    <button type="button" class="btn-secondary" id="clear-btn">&#128465; Clear</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- Batch Scan -->
                <div class="tab-content" id="batch-scan">
                    <div class="panel">
                        <div class="panel-header"><span>&#128202; Batch URL Scanner</span></div>
                        <div class="panel-content">
                            <form id="batch-scan-form">
                                <div class="form-group"><label for="batch-urls">Target URLs (one per line) *</label><textarea id="batch-urls" rows="10" placeholder="http://target1.com/page.php?id=1&#10;http://target2.com/news.php?id=5" required></textarea><small>One URL per line. # for comments.</small></div>
                                <div class="form-group"><label for="batch-options">Scan Options</label><textarea id="batch-options" rows="2" placeholder="--batch --random-agent --level=3"></textarea></div>
                                <div class="batch-stats"><span id="batch-url-count">URLs: 0</span><span id="batch-estimate">Est. Time: N/A</span></div>
                                <div class="button-group"><button type="submit" class="btn-primary" id="batch-scan-btn">&#128640; Start Batch</button><button type="button" class="btn-secondary" id="batch-clear">&#128465; Clear</button></div>
                            </form>
                            <div id="batch-results" style="display:none;margin-top:16px;"><div class="panel-header" style="margin-bottom:12px;"><span>Batch Results</span><span class="scan-meta" id="batch-results-count"></span></div><div id="batch-results-list"></div></div>
                        </div>
                    </div>
                </div>
                <!-- Google Dork -->
                <div class="tab-content" id="google-dork">
                    <div class="panel">
                        <div class="panel-header"><span class="status-indicator" id="dork-status-indicator"></span><span>&#128269; Google Dorking Scanner</span></div>
                        <div class="panel-content">
                            <form id="dork-form">
                                <div class="form-group"><label for="dork-query">Google Dork Query *</label><input type="text" id="dork-query" placeholder="inurl:.php?id= site:.br" required><small>e.g., inurl:.php?id=</small></div>
                                <div class="dork-presets"><span class="preset-label">Quick Presets:</span>
                                    <div class="preset-group-label">SQLi Targets</div>
                                    <div class="preset-buttons">
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id=">PHP ID</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?cat=">PHP Cat</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?item=">PHP Item</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?newsid=">PHP News</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?art=">PHP Art</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?num=">PHP Num</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.asp?id=">ASP ID</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.aspx?id=">ASPX ID</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.jsp?id=">JSP ID</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.cfm?id=">CFM ID</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.pl?id=">Perl ID</button>
                                    </div>
                                    <div class="preset-group-label">Pages & Features</div>
                                    <div class="preset-buttons">
                                        <button type="button" class="preset-btn" data-dork="inurl:search.php?q=">Search</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:product.php?id=">Product</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:category.php?id=">Category</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:news.php?id=">News</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:article.php?id=">Article</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:view.php?id=">View</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:detail.php?id=">Detail</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:gallery.php?id=">Gallery</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:download.php?id=">Download</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:profile.php?id=">Profile</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:page.php?id=">Page</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:content.php?id=">Content</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:shop.php?id=">Shop</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:buy.php?id=">Buy</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:order.php?id=">Order</button>
                                    </div>
                                    <div class="preset-group-label">Error Triggers</div>
                                    <div class="preset-buttons">
                                        <button type="button" class="preset-btn" data-dork="intext:'SQL syntax'">SQL Syntax</button>
                                        <button type="button" class="preset-btn" data-dork="intext:'mysql_fetch_array'">MySQL Fetch</button>
                                        <button type="button" class="preset-btn" data-dork="intext:'Warning: mysql_'">MySQL Warn</button>
                                        <button type="button" class="preset-btn" data-dork="intext:'You have an error in your SQL'">SQL Error</button>
                                        <button type="button" class="preset-btn" data-dork="intext:'ORA-'">Oracle Error</button>
                                        <button type="button" class="preset-btn" data-dork="intext:'PostgreSQL'">PostgreSQL</button>
                                    </div>
                                    <div class="preset-group-label">Target by TLD</div>
                                    <div class="preset-buttons">
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.gov">.gov</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.edu">.edu</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.ac.id">.ac.id</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.co.uk">.co.uk</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.com">.com</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.org">.org</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.net">.net</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.mil">.mil</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.gov.au">.gov.au</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.edu.au">.edu.au</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.ac.uk">.ac.uk</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.ac.jp">.ac.jp</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.de">.de</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.fr">.fr</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.es">.es</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.br">.br</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.in">.in</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.cn">.cn</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.ru">.ru</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.tr">.tr</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.pk">.pk</button>
                                        <button type="button" class="preset-btn" data-dork="inurl:.php?id= site:.bd">.bd</button>
                                    </div>
                                </div></div>
                                <div class="form-row"><div class="form-group"><label for="search-engine">Search Engine</label><select id="search-engine"><option>Google</option><option>Bing</option><option>Yahoo</option><option>DuckDuckGo</option><option>Baidu</option><option>Yandex</option><option>Exalead</option></select></div><div class="form-group"><label for="results-limit">Results Limit</label><input type="number" id="results-limit" value="10" min="1" max="100"></div><div class="form-group"><label for="start-page">Start Page</label><input type="number" id="start-page" value="1" min="1" max="10"></div></div>
                                <details class="advanced-options"><summary>Advanced SQLMap Options</summary><div class="scan-options" style="margin-top:12px;">
                                    <div class="option-checkbox"><input type="checkbox" id="dork-batch" checked><label for="dork-batch">Batch</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="dork-random-agent"><label for="dork-random-agent">Random UA</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="dork-tor"><label for="dork-tor">Tor</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="dork-risk"><label for="dork-risk">Risk 3</label></div>
                                    <div class="option-checkbox"><input type="checkbox" id="dork-level"><label for="dork-level">Level 5</label></div>
                                </div></details>
                                <div class="button-group"><button type="submit" class="btn-primary" id="dork-scan-btn"><span class="btn-text">&#128269; Start Dork</span></button><button type="button" class="btn-secondary" id="dork-stop-btn" disabled>&#9209; Stop</button><button type="button" class="btn-secondary" id="dork-clear-btn">&#128465; Clear</button></div>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- Multi-Dork -->
                <div class="tab-content" id="multi-dork">
                    <div class="panel"><div class="panel-header"><span>&#128203; Multi-Dork Scanner</span></div><div class="panel-content">
                        <form id="multi-dork-form"><div class="form-group"><label for="multi-dorks">Google Dorks (one per line) *</label><textarea id="multi-dorks" rows="6" placeholder="inurl:.php?id=&#10;inurl:.asp?id=" required></textarea><small>One dork per line</small></div><div class="form-row"><div class="form-group"><label for="multi-search-engine">Search Engine</label><select id="multi-search-engine"><option>Google</option><option>Bing</option><option>Yahoo</option><option>DuckDuckGo</option><option>Baidu</option><option>Yandex</option></select></div><div class="form-group"><label for="multi-results-limit">Results Limit</label><input type="number" id="multi-results-limit" value="10" min="1" max="100"></div></div><div class="form-group"><label for="multi-additional-options">Additional Options</label><textarea id="multi-additional-options" rows="2" placeholder="--batch --random-agent"></textarea></div><div class="button-group"><button type="submit" class="btn-primary" id="multi-dork-btn">&#128203; Generate</button><button type="button" class="btn-secondary" id="multi-clear-btn">&#128465; Clear</button></div></form>
                        <div id="multi-dork-results" style="display:none;margin-top:16px;"><div class="panel-header" style="margin-bottom:10px;"><span>Commands</span><span class="scan-meta" id="multi-dork-count"></span></div><div id="multi-dork-commands"></div></div>
                    </div></div>
                </div>
                <!-- Dork Library -->
                <div class="tab-content" id="dork-library">
                    <div class="panel"><div class="panel-header"><span>&#128218; Dork Library</span></div><div class="panel-content">
                        <div class="dork-library-intro"><p>300+ Pre-built Google dork queries. Click to copy or use as preset. Organized by category with difficulty levels.</p>
                            <div class="dork-filter">
                                <input type="text" id="dork-search" placeholder="Search dorks..." class="search-input">
                                <select id="dork-filter-diff" title="Filter by difficulty"><option value="">All Levels</option><option value="easy">Easy</option><option value="medium">Medium</option><option value="hard">Hard</option><option value="advanced">Advanced</option></select>
                            </div>
                        </div>
                        <div class="dork-categories">
                            <div class="dork-category"><h3>&#128279; Basic SQLi URL Dorks</h3><span class="dork-diff easy">Easy</span><div class="dork-list">
                                <div class="dork-item" data-dork="inurl:.php?id="><code>inurl:.php?id=</code><span>PHP numeric ID</span></div>
                                <div class="dork-item" data-dork="inurl:.php?cat="><code>inurl:.php?cat=</code><span>PHP category param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id_cat="><code>inurl:.php?id_cat=</code><span>PHP id_cat param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id_product="><code>inurl:.php?id_product=</code><span>PHP product ID</span></div>
                                <div class="dork-item" data-dork="inurl:.php?idItem="><code>inurl:.php?idItem=</code><span>PHP idItem param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id_news="><code>inurl:.php?id_news=</code><span>PHP news ID</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id_art="><code>inurl:.php?id_art=</code><span>PHP article ID</span></div>
                                <div class="dork-item" data-dork="inurl:.php?idPage="><code>inurl:.php?idPage=</code><span>PHP page ID</span></div>
                                <div class="dork-item" data-dork="inurl:.php?sec="><code>inurl:.php?sec=</code><span>PHP section param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?lang="><code>inurl:.php?lang=</code><span>PHP lang param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?newsID="><code>inurl:.php?newsID=</code><span>PHP newsID param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?idnews="><code>inurl:.php?idnews=</code><span>PHP idnews param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?item_id="><code>inurl:.php?item_id=</code><span>PHP item_id param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?id_mod="><code>inurl:.php?id_mod=</code><span>PHP module ID</span></div>
                                <div class="dork-item" data-dork="inurl:.php?idm="><code>inurl:.php?idm=</code><span>PHP idm param</span></div>
                                <div class="dork-item" data-dork="inurl:.php?idrubrique="><code>inurl:.php?idrubrique=</code><span>PHP rubric ID</span></div>
                            </div></div>
                            <div class="dork-category"><h3>&#128279; Advanced SQLi URL Dorks</h3><span class="dork-diff hard">Hard</span><div class="dork-list">
                                <div class="dork-item" data-dork="inurl:.php?id=&id="><code>inurl:.php?id=&id=</code><span>Double ID param</span></div>
                                <div class="dork-item" data-dork="inurl:file.php?download="><code>inurl:file.php?download=</code><span>File download param</span></div>
                                <div class="dork-item" data-dork="inurl:download.php?id=&file="><code>inurl:download.php?id=&file=</code><span>Download with file param</span></div>
                                <div class="dork-item" data-dork="inurl:newsDetail.php?id="><code>inurl:newsDetail.php?id=</code><span>News detail page</span></div>
                                <div class="dork-item" data-dork="inurl:gallery.php?id="><code>inurl:gallery.php?id=</code><span>Gallery ID param</span></div>
                                <div class="dork-item" data-dork="inurl:productinfo.php?id="><code>inurl:productinfo.php?id=</code><span>Product info page</span></div>
                                <div class="dork-item" data-dork="inurl:section.php?id="><code>inurl:section.php?id=</code><span>Section page ID</span></div>
                                <div class="dork-item" data-dork="inurl:main.php?id="><code>inurl:main.php?id=</code><span>Main page ID</span></div>
                                <div class="dork-item" data-dork="inurl:view_items.php?id="><code>inurl:view_items.php?id=</code><span>View items page</span></div>
                                <div class="dork-item" data-dork="inurl:home.php?id="><code>inurl:home.php?id=</code><span>Home page ID</span></div>

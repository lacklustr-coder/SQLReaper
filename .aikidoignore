# Aikido Ignore File
# Files and directories to exclude from Aikido security scanning

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Build artifacts
dist/
build/
*.egg-info/
*.egg
*.whl

# SQLReaper generated/uploaded files
results/
uploads/
profiles/

# Test files (if any)
tests/
test_*.py
*_test.py

# Documentation
*.md
docs/
LICENSE

# Configuration (already scanned separately)
*.yml
*.yaml
*.json
*.toml

# Static assets
sqlmap_gui/static/css/*
sqlmap_gui/static/js/*
sqlmap_gui/static/img/*
sqlmap_gui/static/fonts/*

# Template files (HTML)
sqlmap_gui/templates/*.html
